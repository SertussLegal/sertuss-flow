{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@shared/*": [
        "./supabase/functions/_shared/isomorphic/*"
      ]
    },
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2020",
    "types": [
      "vitest/globals"
    ],
    "useDefineForClassFields": true
  },
    "include": [
    "src",
    "supabase/functions/_shared/isomorphic/apoderadoClassifier.ts",
    "supabase/functions/_shared/isomorphic/prosaBancos/davivienda.ts",
    "supabase/functions/_shared/isomorphic/prosaBancos/index.ts",
    "supabase/functions/_shared/isomorphic/prosaBancos/types.ts",
    "supabase/functions/_shared/isomorphic/prosaBancos/overrideSchema.ts",
    "supabase/functions/_shared/isomorphic/prosaBancos/mergeOverride.ts",
    "supabase/functions/_shared/isomorphic/prosaBancos/legalProse.ts"
  ]
}