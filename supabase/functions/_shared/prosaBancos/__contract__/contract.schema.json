{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReferenciaProsaBancoContract",
  "type": "object",
  "required": ["bank", "nit", "version", "sources", "ocrSchemaPaths", "prosaAsserts"],
  "properties": {
    "bank": { "type": "string" },
    "nit": { "type": "string" },
    "version": { "type": "string" },
    "generatedAt": { "type": "string" },
    "sources": {
      "type": "object",
      "patternProperties": {
        "^(natural|juridica)$": {
          "type": "object",
          "required": ["bucket", "path", "etag"],
          "properties": {
            "bucket": { "type": "string" },
            "path": { "type": "string" },
            "size": { "type": "integer" },
            "etag": { "type": "string" },
            "capturedAt": { "type": "string" }
          }
        }
      }
    },
    "ocrSchemaPaths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "level"],
        "properties": {
          "path": { "type": "string" },
          "level": { "enum": ["required", "conditional", "recommended"] },
          "requiredIf": { "type": "string" },
          "case": { "type": "array", "items": { "enum": ["natural", "juridica"] } },
          "rationale": { "type": "string" }
        }
      }
    },
    "prosaAsserts": { "type": "object" },
    "stylistic": { "type": "object" }
  }
}
