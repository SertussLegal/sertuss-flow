exports[`prosaBancos: paridad byte-a-byte (snapshots congelados) > JURIDICA limpia — comparecencia + antefirma + nota > juridica.comparecencia 1`] = `"COMPARECIÓ: LINA MAGALY CAMPOS LOSADA, mayor de edad, vecino(a) y domiciliado(a) en la ciudad de Bogotá D.C., identificado(a) con la cédula de ciudadanía número 55069433, manifestó: PRIMERO.- Que en su calidad de representante legal de la sociedad CONECTIVA GLOBAL S.A.S. con NIT. 900.666.582-8, sociedad constituida mediante documento privado del dieciocho (18) de octubre de dos mil trece (2013) de asamblea de accionistas, inscrita en la cámara de comercio de bogota bajo el número 01775236 del libro IX, sociedad que actúa como apoderada general del BANCO DAVIVIENDA S.A., NIT: 860.034.313-7, establecimiento de crédito legalmente constituido, por escritura pública número tres mil ochocientos noventa y dos (3892) de fecha dieciséis (16) de octubre de mil novecientos setenta y dos (1972) otorgada en la Notaría Catorce (14) del Círculo de Bogotá D.C., con domicilio principal en la ciudad de Bogotá D.C., como consta en el poder general conferido por el doctor FELIX ROZO CAGUA, mayor de edad, domiciliado en la ciudad de Bogotá D.C., identificado con cédula de ciudadanía número 79382406 expedida en Bogotá D.C., obrando en su condición de suplente del presidente y como tal representante legal del BANCO DAVIVIENDA S.A., mediante la escritura pública número dieciséis mil trescientos noventa (16390) del dieciocho (18) de septiembre de dos mil veinticinco (2025) otorgado en la Notaría veintinueve (29) del Círculo de Bogotá D.C., cuya copia se protocoliza en el presente instrumento."`;

exports[`prosaBancos: paridad byte-a-byte (snapshots congelados) > JURIDICA limpia — comparecencia + antefirma + nota > juridica.notaAutorizacion 1`] = `"El Suscrito Notario en uso de las atribuciones contempladas en el Artículo doce (12) del Decreto dos mil ciento cuarenta y ocho (2148) de mil novecientos ochenta y tres (1983) y en virtud que LINA MAGALY CAMPOS LOSADA, en calidad de representante legal de la sociedad CONECTIVA GLOBAL S.A.S. con NIT. 900.666.582-8 sociedad que a su vez obra en calidad de apoderada general de BANCO DAVIVIENDA S.A., NIT: 860.034.313-7, tiene registrada su firma en esta Notaría AUTORIZA que el presente instrumento sea suscrito por la persona fuera del recinto notarial en las oficinas de la entidad que representa."`;

exports[`prosaBancos: paridad byte-a-byte (snapshots congelados) > NATURAL con notas adicionales del override — la nota se anexa al PRIMERO > natural.comparecencia.conNotas 1`] = `"COMPARECIÓ: ANA MARIA MONTOYA ECHEVERRY, colombiana, mayor de edad, domiciliada y residente de Bogotá, identificada con la cédula de ciudadanía número 41939243, manifestó: PRIMERO.- Que en su calidad de APODERADA GENERAL del BANCO DAVIVIENDA S.A. NIT: 860.034.313-7, establecimiento Bancario con domicilio principal en la ciudad de Bogotá. En virtud del poder general a el otorgado mediante escritura pública número siete mil trescientos sesenta y cuatro (7364) del veintiséis (26) de mayo de dos mil veintitrés (2023) otorgada en la notaría veintinueve (29) de Bogotá, documento cuya copia se presenta para su protocolización con este instrumento público. Se protocoliza igualmente certificación bancaria de saldo cero."`;

exports[`prosaBancos: paridad byte-a-byte (snapshots congelados) > NATURAL — comparecencia + antefirma + nota > natural.antefirma 1`] = `"ANA MARIA MONTOYA ECHEVERRY C.C. No.41939243 APODERADO GENERAL DE BANCO DAVIVIENDA S.A. – NIT. 860.034.313-7"`;

